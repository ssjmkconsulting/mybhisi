<%- include('partials/header') %>
<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="h2 mb-1"><%= group.name %></h1>
    <p class="text-muted mb-0"><%= group.description || 'No description provided.' %></p>
  </div>
  <span class="badge text-bg-dark">Monthly: <%= toCurrency(group.monthly_contribution) %></span>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <h2 class="h5">Record your contribution</h2>
        <form class="row g-2" method="POST" action="/groups/<%= group.id %>/contributions">
          <div class="col-md-8"><input class="form-control" type="number" step="0.01" min="1" name="amount" placeholder="Amount" required /></div>
          <div class="col-md-4"><button class="btn btn-aurora w-100">Add contribution</button></div>
        </form>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h2 class="h5">Recent contributions</h2>
        <ul class="list-group list-group-flush">
          <% contributions.forEach(item => { %>
            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
              <div>
                <strong><%= item.full_name %></strong>
                <small class="text-muted d-block"><%= toDate(item.paid_at) %></small>
              </div>
              <span class="fw-semibold"><%= toCurrency(item.amount) %></span>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <h2 class="h5">Members</h2>
        <ul class="list-group list-group-flush">
          <% members.forEach(member => { %>
            <li class="list-group-item px-0">
              <strong><%= member.full_name %></strong>
              <small class="text-muted d-block"><%= member.email %> · <%= member.role %></small>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h2 class="h5">Payout schedule</h2>
        <% if (group.is_admin) { %>
          <form class="vstack gap-2 mb-3" method="POST" action="/groups/<%= group.id %>/payouts">
            <input class="form-control" name="recipientEmail" type="email" placeholder="Recipient email" required />
            <input class="form-control" name="payoutDate" type="date" required />
            <input class="form-control" name="amount" type="number" min="1" step="0.01" placeholder="Amount" required />
            <button class="btn btn-outline-dark">Schedule payout</button>
          </form>
        <% } %>
        <ul class="list-group list-group-flush">
          <% payouts.forEach(item => { %>
            <li class="list-group-item px-0 d-flex justify-content-between">
              <div>
                <strong><%= item.recipient %></strong>
                <small class="text-muted d-block"><%= toDate(item.payout_date) %></small>
              </div>
              <span><%= toCurrency(item.amount) %></span>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
